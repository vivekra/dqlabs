# apps/orchestrator/.env.prod.example

# Environment
ENVIRONMENT=production

# Database (Supabase Postgres Transaction Pooler URL)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Redis Broker for Celery (Running in the same docker-compose stack)
REDIS_URL=redis://redis:6379/0

# Supabase Auth for JWT verification
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# K8s Config
KUBECONFIG_PATH=/root/.kube/config
STORAGE_CLASS=local-path

# Domain Routing
# Defaulting to localhost/127.0.0.1.nip.io for local VPS testing
INGRESS_DOMAIN_SUFFIX=127.0.0.1.nip.io

# Workspace Limits
IDLE_TIMEOUT_MINUTES=30
