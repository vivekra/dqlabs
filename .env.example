# ==============================================================================
# DigitalQ Labs - Global Environment Variables Template
# ==============================================================================

# Core Application Environment
ENVIRONMENT=development # development, staging, production
SECRET_KEY=generate_a_long_secure_random_string_here_for_prod

# ------------------------------------------------------------------------------
# 1. PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecretpassword123
POSTGRES_DB=digitalq_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:supersecretpassword123@postgres:5432/digitalq_dev

# ------------------------------------------------------------------------------
# 2. Redis Configuration
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 3. Supabase Local Configuration
# ------------------------------------------------------------------------------
SUPABASE_URL=http://localhost:9999
SUPABASE_JWT_SECRET=supersecretjwtsecretstring1234567890
SUPABASE_ANON_KEY=dev_supabase_anon_key_string
SUPABASE_SERVICE_ROLE_KEY=dev_supabase_service_role_key_string

# ------------------------------------------------------------------------------
# 4. Paymenter Billing Configuration
# ------------------------------------------------------------------------------
PAYMENTER_URL=http://paymenter:80
PAYMENTER_API_KEY=dev_paymenter_api_key_abc123

# ------------------------------------------------------------------------------
# 5. Object Storage (MinIO)
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword123
MINIO_USE_SSL=false

# ------------------------------------------------------------------------------
# 6. AI Gateway Configuration
# ------------------------------------------------------------------------------
AI_MODE=hybrid # hybrid, openai_only, ollama_only
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL_DEFAULT=llama3 # llama3, mistral, deepseek-coder, phi

# ------------------------------------------------------------------------------
# 7. Local SMTP (MailHog) Configuration
# ------------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=no-reply@digitalqlabs.io
